@inherits LayoutComponentBase
@inject ApiService Api
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

@* CascadingAuthenticationState lives in Routes.razor — do NOT add it here. *@

<div class="layout-wrapper">
    <header class="app-header">

        @* Left: identity when logged in, empty otherwise *@
        <div class="header-side header-side--left">
            <AuthorizeView>
                <Authorized>
                    <div class="identity-area d-flex align-items-center gap-2">
                        <span class="identity-name">
                            <strong>@context.User.Identity?.Name</strong>
                        </span>
                        @if (context.User.IsInRole("Admin"))
                        {
                            <a href="/admin" class="nav-btn nav-btn-admin">
                                Centre de Contrôle
                            </a>
                        }
                        <button class="nav-btn nav-btn-logout" @onclick="HandleLogout"
                                disabled="@_loading">
                            Déconnexion
                        </button>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        @* Center: animated brand logo *@
        <div class="header-center">
            <a href="/" class="header-logo-link">
                <img src="/images/joli-gateaux.gif" alt="Joli Gâteaux" class="header-logo" />
            </a>
        </div>

        @* Right: subtle Admin trigger (only when not logged in) *@
        <div class="header-side header-side--right">
            <AuthorizeView>
                <NotAuthorized>
                    <button class="nav-btn-admin-subtle" @onclick="ToggleAdminModal">
                        Admin
                    </button>
                </NotAuthorized>
            </AuthorizeView>
        </div>

    </header>

    <main class="app-main">
        @Body
    </main>
</div>

@* ── Admin Login Modal ─────────────────────────────────────────────────── *@
@if (_showAdminModal)
{
    <div class="admin-modal-backdrop" @onclick="ToggleAdminModal">
        <div class="admin-modal-card" @onclick:stopPropagation="true">

            <div class="admin-modal-icon">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h5 class="admin-modal-title">Accès Administrateur</h5>
            <p class="admin-modal-subtitle">Entrez le mot de passe pour continuer.</p>

            <input type="password"
                   class="form-control mb-2"
                   placeholder="Mot de passe"
                   @bind="_adminPassword"
                   @bind:event="oninput"
                   @onkeydown="HandleAdminKeyDown"
                   disabled="@_loading" />

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="admin-modal-error mb-2">@_error</p>
            }

            @if (_loading)
            {
                <div class="text-center py-2">
                    <div class="spinner-border spinner-border-sm"
                         style="color: #007AFF;" role="status"></div>
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <button class="apple-action-btn apple-btn-gray flex-fill"
                        @onclick="ToggleAdminModal"
                        disabled="@_loading">
                    Annuler
                </button>
                <button class="apple-action-btn apple-btn-blue flex-fill"
                        @onclick="AdminLogin"
                        disabled="@(_loading || string.IsNullOrEmpty(_adminPassword))">
                    Valider
                </button>
            </div>

        </div>
    </div>
}

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">✕</a>
</div>

@code {
    private bool   _showAdminModal;
    private string _adminPassword = string.Empty;
    private string _error         = string.Empty;
    private bool   _loading;

    private CustomAuthStateProvider AuthState =>
        (CustomAuthStateProvider)AuthProvider;

    private void ToggleAdminModal()
    {
        _showAdminModal = !_showAdminModal;
        _adminPassword  = string.Empty;
        _error          = string.Empty;
    }

    private async Task AdminLogin()
    {
        if (string.IsNullOrWhiteSpace(_adminPassword)) return;
        _loading = true;
        _error   = string.Empty;
        try
        {
            var result = await Api.AdminLoginAsync("Bachir", _adminPassword);
            if (result is not null)
            {
                await AuthState.MarkUserAsAuthenticated(result.Token);
                _showAdminModal = false;
                Nav.NavigateTo("/admin", forceLoad: true);
            }
            else
            {
                _error = "Mot de passe invalide.";
            }
        }
        catch
        {
            _error = "Erreur réseau — vérifiez la connexion.";
        }
        finally
        {
            _loading       = false;
            _adminPassword = string.Empty;
        }
    }

    private async Task HandleAdminKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AdminLogin();
    }

    private async Task HandleLogout()
    {
        _loading = true;
        await AuthState.Logout();
        Nav.NavigateTo("/", forceLoad: true);
    }
}
