@page "/call/{ReservationId:guid?}"
@rendermode InteractiveServer
@inject ApiService ApiService
@inject NavigationManager Nav

<PageTitle>Log Call — CallLog CRM</PageTitle>

<div class="call-container">

    @if (_loadingReservation)
    {
        <div class="text-center py-4">
            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
            <p class="text-muted small mt-2">Chargement de la réservation…</p>
        </div>
    }
    else if (_step == 1)
    {
        <span class="step-badge">Étape 1 sur 3</span>
        <p class="call-question">Qui appelez-vous ?</p>

        <div class="mb-3">
            <label class="form-label fw-semibold">Nom du client</label>
            <input class="form-control form-control-lg"
                   @bind="_customerName"
                   @bind:event="oninput"
                   placeholder="Nom complet"
                   readonly="@_prefilled" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Numéro de téléphone</label>
            <input class="form-control form-control-lg"
                   @bind="_phoneNumber"
                   @bind:event="oninput"
                   placeholder="+33 6 00 00 00 00"
                   type="tel"
                   readonly="@_prefilled" />
        </div>

        @if (_validationError is not null)
        {
            <div class="alert alert-warning py-2 small">@_validationError</div>
        }

        <button class="btn btn-primary btn-action mt-1" @onclick="GoToStep2">
            Suivant →
        </button>

        @if (_prefilled)
        {
            <p class="text-muted small mt-2">
                Pré-rempli depuis la réservation. <a href="/call" class="text-decoration-underline">Saisir manuellement</a>
            </p>
        }
    }

    else if (_step == 2)
    {
        <span class="step-badge">Étape 2 sur 3</span>
        <p class="call-question">@_customerName a répondu ?</p>

        <button class="btn btn-success btn-action" @onclick='() => GoToStep3(true)'>
            Oui — A répondu
        </button>
        <button class="btn btn-secondary btn-action" @onclick='() => GoToStep3(false)'>
            Non — Pas de réponse
        </button>

        <button class="btn btn-link btn-back d-block mt-2" @onclick='() => _step = 1'>
            ← Retour
        </button>
    }

    else if (_step == 3 && _answered == true)
    {
        <span class="step-badge">Étape 3 sur 3</span>
        <p class="call-question">Comment s'est passé l'appel ?</p>

        <button class="btn btn-success btn-action" disabled="@_submitting"
                @onclick='() => Submit("Answered_Available")'>
            Disponible — Appel réussi
        </button>
        <button class="btn btn-warning btn-action" disabled="@_submitting"
                @onclick='() => Submit("Answered_NotAvailable")'>
            Pas Disponible — Rappeler plus tard
        </button>

        <button class="btn btn-link btn-back d-block mt-2" @onclick='() => _step = 2'>
            ← Retour
        </button>
    }

    else if (_step == 3 && _answered == false)
    {
        <span class="step-badge">Étape 3 sur 3</span>
        <p class="call-question">Que s'est-il passé ?</p>

        <button class="btn btn-primary btn-action" disabled="@_submitting"
                @onclick='() => Submit("NotAnswered_VoicemailLeft")'>
            Messagerie Laissée
        </button>
        <button class="btn btn-warning btn-action" disabled="@_submitting"
                @onclick='() => Submit("NotAnswered_NoVoicemail")'>
            Pas de Messagerie — A Sonné
        </button>
        <button class="btn btn-danger btn-action" disabled="@_submitting"
                @onclick='() => Submit("NotAnswered_VoicemailFull")'>
            Messagerie Pleine
        </button>

        <button class="btn btn-link btn-back d-block mt-2" @onclick='() => _step = 2'>
            ← Retour
        </button>
    }

    @if (_submitting)
    {
        <div class="text-center mt-3">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted small mt-2">Enregistrement…</p>
        </div>
    }

    @if (_error is not null)
    {
        <div class="alert alert-danger mt-3 py-2 small">
            @_error
            <button class="btn btn-sm btn-outline-danger ms-2" @onclick='() => _error = null'>Fermer</button>
        </div>
    }

</div>

@code {
    [Parameter] public Guid? ReservationId { get; set; }

    private int     _step               = 1;
    private bool?   _answered;
    private string  _customerName       = string.Empty;
    private string  _phoneNumber        = string.Empty;
    private string? _validationError;
    private string? _error;
    private bool    _submitting;
    private bool    _prefilled;
    private bool    _loadingReservation;

    protected override async Task OnInitializedAsync()
    {
        if (ReservationId is null) return;

        _loadingReservation = true;
        try
        {
            var reservation = await ApiService.GetReservationAsync(ReservationId.Value);
            if (reservation is not null)
            {
                _customerName = reservation.CustomerName;
                _phoneNumber  = reservation.PhoneNumber;
                _prefilled    = true;
            }
        }
        catch
        {
            // If fetching fails, user can still type manually.
        }
        finally
        {
            _loadingReservation = false;
        }
    }

    private void GoToStep2()
    {
        if (string.IsNullOrWhiteSpace(_customerName) || string.IsNullOrWhiteSpace(_phoneNumber))
        {
            _validationError = "Veuillez remplir le nom du client et le numéro de téléphone.";
            return;
        }
        _validationError = null;
        _step = 2;
    }

    private void GoToStep3(bool answered)
    {
        _answered = answered;
        _step = 3;
    }

    private async Task Submit(string outcome)
    {
        _submitting = true;
        _error      = null;
        try
        {
            var success = await ApiService.CreateCallLogAsync(new CreateCallLogRequest
            {
                CustomerName = _customerName,
                PhoneNumber  = _phoneNumber,
                Outcome      = outcome
            });

            if (success)
                Nav.NavigateTo("/");
            else
                _error = "Le serveur a renvoyé une erreur. Veuillez réessayer.";
        }
        catch (Exception ex)
        {
            _error = $"Échec de l'envoi : {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
