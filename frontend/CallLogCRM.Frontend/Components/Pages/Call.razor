    private string  _customerName       = string.Empty;
    private string? _email;
    private string  _phoneNumber        = string.Empty;
    private string? _notesFaits;
    private string? _notesEmotions;
    private string? _paymentNotes;
    private string? _refusalNotes;
    private string? _earlyExitNotes;
    private decimal _revenue         = 0;
    private decimal _amountCollected = 0;
    private string  _pendingStatus  = string.Empty;
    private string? _callStatus;
    private string  _activeObjection     = string.Empty;
    private string? _validationError;
    private string? _error;
    private bool    _submitting;
    private bool    _prefilled;
    private bool    _loadingReservation;

    protected override async Task OnInitializedAsync()
    {
        if (ReservationId is null) return;

        _loadingReservation = true;
        try
        {
            var reservation = await ApiService.GetReservationAsync(ReservationId.Value);
            if (reservation is not null)
            {
                _customerName = reservation.CustomerName;
                _email        = reservation.Email;
                _phoneNumber  = reservation.PhoneNumber;
                _prefilled    = true;
            }
        }
        catch
        {
            // If fetching fails, user can still type manually.
        }
        finally
        {
            _loadingReservation = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/");

    private void GoToStep2()
    {
        if (string.IsNullOrWhiteSpace(_customerName) || string.IsNullOrWhiteSpace(_phoneNumber))
        {
            _validationError = "Veuillez remplir le nom du client et le numéro de téléphone.";
            return;
        }
        _validationError = null;
        _scriptPhase     = 1;
        _step            = 2;
    }

    private void ProspectAnswered()           => _scriptPhase = 2;
    private void ClientSouhaiteContinuer()    => _scriptPhase = 3;
    private void DouleurIdentifiee()          => _scriptPhase = 4;
    private void ProspectQualifie()           => _scriptPhase = 5;
    private void PriseDeConscienceValidee()   => _scriptPhase = 6;
    private void PresenterOffre()             => _scriptPhase = 7;
    private void ClientAccepte()              => _scriptPhase = 8;
    private void ClientRefuse()               => _scriptPhase = 9;
    private void ProspectNaPasRepondu()       => _scriptPhase = 10;
    private void ShowObjection(string key)    => _activeObjection = key;

    private void TriggerEarlyExit(string status)
    {
        _pendingStatus = status;
        _scriptPhase   = 11;
    }

    private string CurrentPhaseTitle => _scriptPhase switch
    {
        1  => $"{_customerName} a répondu ?",
        2  => "Lancement de l'Appel",
        3  => "Phase de Découverte (Les 3 Piliers)",
        4  => "La Transition",
        5  => "Prise de Conscience & Récapitulatif",
        6  => "État d'Esprit Entrepreneur",
        7  => "L'Offre & Le Prix (Le Closing)",
        8  => "Encaissement du Client",
        9  => "Refus Définitif",
        10 => "Appel Sans Réponse (Suivi)",
        11 => "Fin Prématurée de l'Appel",
        _  => "Appel en cours…"
    };

    private async Task SaveAndEndCall(string status)
    {
        _callStatus = status;
        var notes = !string.IsNullOrWhiteSpace(_earlyExitNotes) ? _earlyExitNotes
                  : !string.IsNullOrWhiteSpace(_refusalNotes)   ? _refusalNotes
                  : !string.IsNullOrWhiteSpace(_paymentNotes)   ? _paymentNotes
                  : status;
        await Submit("NotAnswered_NoVoicemail", notes: notes);
    }

    private void GoToStep3(bool answered)
    {
        _answered = answered;
        _step = 3;
    }

    private async Task Submit(string outcome, string? notes = null, decimal revenue = 0, decimal amountCollected = 0)
    {
        _submitting = true;
        _error      = null;
        try
        {
            var success = await ApiService.CreateCallLogAsync(new CreateCallLogRequest
            {
                CustomerName    = _customerName,
                PhoneNumber     = _phoneNumber,
                Outcome         = outcome,
                Notes           = notes,
                Revenue         = revenue,
                AmountCollected = amountCollected
            });

            if (success)
                Nav.NavigateTo("/");
            else
                _error = "Le serveur a renvoyé une erreur. Veuillez réessayer.";
        }
        catch (Exception ex)
        {
            _error = $"Échec de l'envoi : {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
