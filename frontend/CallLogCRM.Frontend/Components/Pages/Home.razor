@page "/"
@rendermode InteractiveServer
@inject ApiService ApiService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<PageTitle>CallLog CRM</PageTitle>

<div class="home-container">

    <AuthorizeView>
        @* ── Not logged in ──────────────────────────── *@
        <NotAuthorized>
            <div class="hero-section">
                <h1>Bienvenue sur CallLog CRM</h1>
                <p class="text-muted">
                    Sélectionnez votre identité en haut à droite pour voir votre queue d'appels.
                </p>
            </div>
        </NotAuthorized>

        @* ── Logged in ──────────────────────────────── *@
        <Authorized>
            <div class="hero-section">
                <h1>Ma Queue d'Appels</h1>
                <p>Bonjour, <strong>@context.User.Identity?.Name</strong> 👋</p>
            </div>

            <hr class="section-divider" />

            @if (_loading)
            {
                <div class="text-center py-4">
                    <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                </div>
            }
            else if (_error is not null)
            {
                <div class="alert alert-danger py-2 small">@_error</div>
            }
            else if (_reservations.Count == 0)
            {
                <p class="text-muted text-center py-4 small">
                    Aucune réservation assignée. Revenez plus tard ou contactez votre admin.
                </p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Client</th>
                                <th>Téléphone</th>
                                <th>Rendez-vous</th>
                                <th>Source</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in _reservations)
                            {
                                var callUrl = $"/call/{r.Id}";
                                <tr @onclick="() => Nav.NavigateTo(callUrl)" class="queue-row">
                                    <td class="fw-medium">@r.CustomerName</td>
                                    <td class="text-muted small">@r.PhoneNumber</td>
                                    <td class="small">
                                        @(r.AppointmentDate == DateTime.MinValue
                                            ? "À définir"
                                            : r.AppointmentDate.ToLocalTime().ToString("dd MMM yyyy 'à' HH:mm"))
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary bg-opacity-25 text-dark small">
                                            @r.Source
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(r.CurrentStatus))
                                        {
                                            <span class="status-badge @StatusCss(r.CurrentStatus)">
                                                @r.CurrentStatus
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-call">
                                                ▶ Lancer l'appel
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <hr class="section-divider" />

            @* ── Recent Call History ─────────────────── *@
            <div>
                <div class="history-header">
                    <h6 class="mb-0 fw-bold text-uppercase text-muted" style="letter-spacing:.05em">
                        Historique Récent
                    </h6>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAll" disabled="@_loading">
                        Rafraîchir
                    </button>
                </div>

                @if (_logs.Count == 0)
                {
                    <p class="text-muted text-center py-3 small">Aucun appel enregistré.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Client</th>
                                    <th>Téléphone</th>
                                    <th>Résultat</th>
                                    <th>Heure</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in _logs)
                                {
                                    <tr>
                                        <td class="fw-medium">@log.CustomerName</td>
                                        <td class="text-muted small">@log.PhoneNumber</td>
                                        <td>
                                            <span class="outcome-badge @OutcomeCss(log.Outcome)">
                                                @FormatOutcome(log.Outcome)
                                            </span>
                                            @if (!string.IsNullOrWhiteSpace(log.Notes))
                                            {
                                                <div class="text-muted" style="font-size:.7rem">@log.Notes</div>
                                            }
                                        </td>
                                        <td class="text-muted small">
                                            @log.CreatedAt.ToLocalTime().ToString("dd MMM, HH:mm")
                                        </td>
                                        <td class="text-end">
                                            @if (log.Id != Guid.Empty)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary border-0"
                                                        @onclick="() => EditCallLog(log.Id)"
                                                        title="Modifier l'entrée">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </Authorized>
    </AuthorizeView>

</div>

@code {
    private List<CallReservation> _reservations = [];
    private List<CallLog>         _logs         = [];
    private bool                  _loading      = true;
    private string?               _error;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.IsInRole("Admin"))
        {
            Nav.NavigateTo("/admin", replace: true);
            return;
        }
        await LoadAll();
    }

    private async Task LoadAll()
    {
        _loading = true;
        _error   = null;
        try
        {
            var allReservations = await ApiService.GetMyReservationsAsync();
            var actualLogs      = await ApiService.GetMyCallLogsAsync();

            // Queue: only reservations that have no status yet (closer hasn't touched them).
            _reservations = allReservations
                .Where(r => string.IsNullOrWhiteSpace(r.CurrentStatus))
                .ToList();

            // Sheet-only updates: reservations WITH a status but NO matching call log entry.
            // Matched by phone number since CallLog has no ReservationId FK on the frontend.
            var sheetUpdates = allReservations
                .Where(r => !string.IsNullOrWhiteSpace(r.CurrentStatus)
                         && !actualLogs.Any(c => c.PhoneNumber == r.PhoneNumber))
                .Select(r => new CallLog
                {
                    Id           = Guid.Empty,
                    CustomerName = r.CustomerName,
                    PhoneNumber  = r.PhoneNumber,
                    Outcome      = r.CurrentStatus!,
                    Notes        = "Mis à jour via Google Sheets",
                    CreatedAt    = r.AppointmentDate == DateTime.MinValue
                                       ? DateTime.UtcNow
                                       : r.AppointmentDate
                });

            _logs = actualLogs
                .Concat(sheetUpdates)
                .OrderByDescending(l => l.CreatedAt)
                .ToList();
        }
        catch (Exception ex)
        {
            _error = $"Impossible de charger les données : {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Status badge CSS ─────────────────────────────
    private static string StatusCss(string status)
    {
        var s = status.Trim().ToLowerInvariant();
        if (s.Contains("vente") && !s.Contains("pas"))              return "status-vente";
        if (s.Contains("pas de vente") || s.Contains("pas vente")) return "status-pas-vente";
        if (s.Contains("rdv") || s.Contains("confirm"))            return "status-rdv";
        if (s.Contains("rappel"))                                   return "status-rappel";
        return "status-autre";
    }

    // ── Outcome helpers ──────────────────────────────
    private static string FormatOutcome(string outcome) => outcome switch
    {
        "Answered_Available"        => "Répondu — Disponible",
        "Answered_NotAvailable"     => "Répondu — Pas Disponible",
        "NotAnswered_VoicemailLeft" => "Pas Répondu — Messagerie",
        "NotAnswered_NoVoicemail"   => "Pas Répondu — Aucun message",
        "NotAnswered_VoicemailFull" => "Pas Répondu — Messagerie Pleine",
        _                           => outcome
    };

    private static string OutcomeCss(string outcome) =>
        outcome.StartsWith("Answered") ? "outcome-answered" : "outcome-not-answered";

    // ── History actions ──────────────────────────────
    private void EditCallLog(Guid id)
    {
        // TODO: navigate to an edit page or open a modal for the selected call log.
        Nav.NavigateTo($"/call-log/{id}/edit");
    }
}
