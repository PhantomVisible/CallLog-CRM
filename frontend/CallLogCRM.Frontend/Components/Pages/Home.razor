@page "/"
@rendermode InteractiveServer
@inject ApiService ApiService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<PageTitle>Joli Gâteaux — CRM</PageTitle>

<div class="home-container">

    <AuthorizeView>

        @* ── Not logged in ──────────────────────────── *@
        <NotAuthorized>

            @if (!_showUserGrid)
            {
                @* Hero landing screen *@
                <div class="hero-login">
                    <h1 class="hero-login-title">Bonjour.</h1>
                    <p class="hero-login-sub">
                        Sélectionnez votre profil pour accéder à votre queue d'appels.
                    </p>
                    <button class="hero-connexion-btn" @onclick="RevealGrid">
                        Connexion
                    </button>
                </div>
            }
            else
            {
                @* Closeuse selection grid *@
                <div class="user-grid-header">
                    <h2 class="user-grid-title">Qui êtes-vous ?</h2>
                    <p class="user-grid-sub">Appuyez sur votre nom pour vous connecter.</p>
                </div>

                <div class="row row-cols-2 row-cols-md-4 g-4 justify-content-center">
                    @foreach (var closeuse in _closeuses)
                    {
                        var name = closeuse;
                        <div class="col">
                            <div class="apple-card user-card">
                                <div class="user-card-avatar">
                                    <i class="bi bi-person-circle"></i>
                                </div>
                                <div class="user-card-name">@name</div>
                                <button class="user-card-btn"
                                        disabled="@_loadingLogin"
                                        @onclick="() => SelectCloser(name)">
                                    @if (_loadingUser == name)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status"></span>
                                    }
                                    else
                                    {
                                        <span>Connexion</span>
                                    }
                                </button>
                            </div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_loginError))
                {
                    <div class="apple-alert apple-alert-danger mt-4 text-center">
                        @_loginError
                    </div>
                }
            }

        </NotAuthorized>

        @* ── Logged in ──────────────────────────────── *@
        <Authorized>

            @* ── Page header ── *@
            <div class="d-flex justify-content-between align-items-end mb-4 pt-2">
                <div>
                    <h1 class="fw-bolder mb-1" style="letter-spacing: -1px; color: #1D1D1F; font-size: clamp(1.75rem, 4vw, 2.25rem);">
                        Ma Queue d'Appels
                    </h1>
                    <p style="color: #86868B; font-size: 0.9rem; margin: 0;">
                        Bonjour, <strong style="color: #3A3A3C;">@context.User.Identity?.Name</strong>
                    </p>
                </div>
                <button class="apple-btn-refresh" @onclick="LoadAll" disabled="@_loading">
                    Rafraîchir
                </button>
            </div>

            @* ── Queue ── *@
            @if (_loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border" style="color: #007AFF; width: 1.5rem; height: 1.5rem;" role="status"></div>
                </div>
            }
            else if (_error is not null)
            {
                <div class="apple-alert apple-alert-danger mb-4">@_error</div>
            }
            else if (_reservations.Count == 0)
            {
                <div class="apple-card mb-4" style="padding: 2rem 1.5rem; text-align: center;">
                    <p style="color: #86868B; font-size: 0.9rem; margin: 0;">
                        Aucune réservation assignée. Revenez plus tard ou contactez votre admin.
                    </p>
                </div>
            }
            else
            {
                <div class="apple-card mb-4" style="overflow: hidden;">
                    <div class="table-responsive">
                        <table class="apple-table">
                            <thead>
                                <tr>
                                    <th>Client</th>
                                    <th>Téléphone</th>
                                    <th>Rendez-vous</th>
                                    <th>Source</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _reservations)
                                {
                                    var callUrl = $"/call/{r.Id}";
                                    <tr @onclick="() => Nav.NavigateTo(callUrl)" class="queue-row">
                                        <td style="font-weight: 600; font-size: 0.9rem;">@r.CustomerName</td>
                                        <td style="color: #86868B; font-size: 0.825rem;">@r.PhoneNumber</td>
                                        <td style="font-size: 0.825rem;">
                                            @(r.AppointmentDate == DateTime.MinValue
                                                ? "À définir"
                                                : r.AppointmentDate.ToLocalTime().ToString("dd MMM yyyy 'à' HH:mm"))
                                        </td>
                                        <td>
                                            <span class="rate-pill">@r.Source</span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(r.CurrentStatus))
                                            {
                                                <span class="status-badge @StatusCss(r.CurrentStatus)">
                                                    @r.CurrentStatus
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-call">
                                                    ▶ Lancer l'appel
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* ── Recent History ── *@
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: #86868B;">
                    Historique Récent
                </span>
            </div>

            @if (_logs.Count == 0)
            {
                <div class="apple-card" style="padding: 2rem 1.5rem; text-align: center;">
                    <p style="color: #86868B; font-size: 0.875rem; margin: 0;">Aucun appel enregistré.</p>
                </div>
            }
            else
            {
                <div class="apple-card" style="overflow: hidden;">
                    <div class="table-responsive">
                        <table class="apple-table">
                            <thead>
                                <tr>
                                    <th>Client</th>
                                    <th>Téléphone</th>
                                    <th>Résultat</th>
                                    <th>Heure</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in _logs)
                                {
                                    <tr>
                                        <td style="font-weight: 600; font-size: 0.875rem;">@log.CustomerName</td>
                                        <td style="color: #86868B; font-size: 0.825rem;">@log.PhoneNumber</td>
                                        <td>
                                            <span class="outcome-badge @OutcomeCss(log.Outcome)">
                                                @FormatOutcome(log.Outcome)
                                            </span>
                                            @if (!string.IsNullOrWhiteSpace(log.Notes))
                                            {
                                                <div style="font-size: 0.72rem; color: #86868B; margin-top: 0.2rem; font-style: italic;">
                                                    @log.Notes
                                                </div>
                                            }
                                        </td>
                                        <td style="color: #86868B; font-size: 0.8rem; white-space: nowrap;">
                                            @log.CreatedAt.ToLocalTime().ToString("dd MMM, HH:mm")
                                        </td>
                                        <td class="text-end">
                                            @if (log.Id != Guid.Empty)
                                            {
                                                <button class="apple-back-link"
                                                        @onclick="() => EditCallLog(log.Id)"
                                                        title="Modifier l'entrée">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

        </Authorized>
    </AuthorizeView>

</div>

@code {
    // ── Pre-login state ──────────────────────────────────────────────────
    private bool   _showUserGrid;
    private bool   _loadingLogin;
    private string _loadingUser = string.Empty;
    private string _loginError  = string.Empty;

    private static readonly List<string> _closeuses =
    [
        "Hayat Mahir",
        "Amel K",
        "Sakina Slimani",
        "Kowsar Abdi",
        "Jennifer",
        "Batoul",
        "Ines",
        "Amel"
    ];

    // ── Post-login state ─────────────────────────────────────────────────
    private List<CallReservation> _reservations = [];
    private List<CallLog>         _logs         = [];
    private bool                  _loading      = true;
    private string?               _error;

    private CustomAuthStateProvider AuthState =>
        (CustomAuthStateProvider)AuthProvider;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.IsInRole("Admin"))
        {
            Nav.NavigateTo("/admin", replace: true);
            return;
        }
        if (state.User.Identity?.IsAuthenticated == true)
            await LoadAll();
        else
            _loading = false;
    }

    // ── Closeuse selection ───────────────────────────────────────────────
    private void RevealGrid() => _showUserGrid = true;

    private async Task SelectCloser(string name)
    {
        _loadingLogin = true;
        _loadingUser  = name;
        _loginError   = string.Empty;
        try
        {
            var result = await ApiService.SelectCloserAsync(name);
            if (result is not null)
            {
                await AuthState.MarkUserAsAuthenticated(result.Token);
                Nav.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _loginError = "Identité non reconnue. Contactez votre admin.";
            }
        }
        catch
        {
            _loginError = "Erreur réseau — vérifiez la connexion.";
        }
        finally
        {
            _loadingLogin = false;
            _loadingUser  = string.Empty;
        }
    }

    // ── Queue + history loading ──────────────────────────────────────────
    private async Task LoadAll()
    {
        _loading = true;
        _error   = null;
        try
        {
            var allReservations = await ApiService.GetMyReservationsAsync();
            var actualLogs      = await ApiService.GetMyCallLogsAsync();

            _reservations = allReservations
                .Where(r => string.IsNullOrWhiteSpace(r.CurrentStatus))
                .ToList();

            var sheetUpdates = allReservations
                .Where(r => !string.IsNullOrWhiteSpace(r.CurrentStatus)
                         && !actualLogs.Any(c => c.PhoneNumber == r.PhoneNumber))
                .Select(r => new CallLog
                {
                    Id           = Guid.Empty,
                    CustomerName = r.CustomerName,
                    PhoneNumber  = r.PhoneNumber,
                    Outcome      = r.CurrentStatus!,
                    Notes        = "Mis à jour via Google Sheets",
                    CreatedAt    = r.AppointmentDate == DateTime.MinValue
                                       ? DateTime.UtcNow
                                       : r.AppointmentDate
                });

            _logs = actualLogs
                .Concat(sheetUpdates)
                .OrderByDescending(l => l.CreatedAt)
                .ToList();
        }
        catch (Exception ex)
        {
            _error = $"Impossible de charger les données : {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Status badge CSS ─────────────────────────────────────────────────
    private static string StatusCss(string status)
    {
        var s = status.Trim().ToLowerInvariant();
        if (s.Contains("vente") && !s.Contains("pas"))              return "status-vente";
        if (s.Contains("pas de vente") || s.Contains("pas vente")) return "status-pas-vente";
        if (s.Contains("rdv") || s.Contains("confirm"))            return "status-rdv";
        if (s.Contains("rappel"))                                   return "status-rappel";
        return "status-autre";
    }

    // ── Outcome helpers ──────────────────────────────────────────────────
    private static string FormatOutcome(string outcome) => outcome switch
    {
        "Answered_Available"        => "Répondu — Disponible",
        "Answered_NotAvailable"     => "Répondu — Pas Disponible",
        "NotAnswered_VoicemailLeft" => "Pas Répondu — Messagerie",
        "NotAnswered_NoVoicemail"   => "Pas Répondu — Aucun message",
        "NotAnswered_VoicemailFull" => "Pas Répondu — Messagerie Pleine",
        _                           => outcome
    };

    private static string OutcomeCss(string outcome) =>
        outcome.StartsWith("Answered") ? "outcome-answered" : "outcome-not-answered";

    // ── History actions ──────────────────────────────────────────────────
    private void EditCallLog(Guid id)
    {
        Nav.NavigateTo($"/call-log/{id}/edit");
    }
}
