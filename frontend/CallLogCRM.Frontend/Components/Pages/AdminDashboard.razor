@page "/admin"
@rendermode InteractiveServer
@inject ApiService ApiService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@using System.Globalization

<PageTitle>Centre de Contrôle — CallLog CRM</PageTitle>

@if (_loading)
{
    <div class="admin-loading">
        <div class="spinner-border" style="color: #007AFF; width: 1.75rem; height: 1.75rem;" role="status"></div>
        <span>Chargement des données…</span>
    </div>
}
else if (_error is not null)
{
    <div class="admin-page pt-4">
        <div style="background: #FFE5E5; color: #C0392B; border-radius: 16px; padding: 1.25rem 1.5rem; font-size: 0.9rem; font-weight: 500;">
            @_error
        </div>
    </div>
}
else
{
    var fr = new CultureInfo("fr-FR");

    <div class="admin-page">

        @* ── Header ─────────────────────────────────────────────── *@
        <div class="d-flex justify-content-between align-items-end mb-5 pt-2">
            <div>
                <h1 class="apple-page-title">Centre de Contrôle</h1>
                <p class="apple-page-subtitle">Tableau de bord des performances</p>
            </div>
            <button class="apple-btn-refresh" @onclick="LoadData">Rafraîchir</button>
        </div>

        @* ── Ligne 1 : KPIs Financiers ──────────────────────────── *@
        <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
                <div class="apple-card apple-kpi-card h-100">
                    <span class="apple-kpi-label">CA Total</span>
                    <p class="apple-kpi-value kv-green">@_totalRevenue.ToString("C0", fr)</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="apple-card apple-kpi-card h-100">
                    <span class="apple-kpi-label">Cash Collecté</span>
                    <p class="apple-kpi-value kv-mint">@_totalCollected.ToString("C0", fr)</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="apple-card apple-kpi-card h-100">
                    <span class="apple-kpi-label">Acheteurs</span>
                    <p class="apple-kpi-value kv-blue">@_numberOfBuyers</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="apple-card apple-kpi-card h-100">
                    <span class="apple-kpi-label">Panier Moyen Collecté</span>
                    <p class="apple-kpi-value kv-teal">@_averageOrderValue.ToString("C0", fr)</p>
                </div>
            </div>
        </div>

        @* ── Ligne 2 : KPIs Appels ──────────────────────────────── *@
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="apple-card apple-kpi-card h-100">
                    <span class="apple-kpi-label">Appels Totaux</span>
                    <p class="apple-kpi-value">@_totalCalls</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="apple-card apple-kpi-card h-100">
                    <span class="apple-kpi-label">Ventes Conclues</span>
                    <p class="apple-kpi-value kv-green">@_totalSales</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="apple-card apple-kpi-card h-100">
                    <span class="apple-kpi-label">Taux de Conversion</span>
                    <p class="apple-kpi-value kv-orange">@_conversionRate %</p>
                </div>
            </div>
        </div>

        @* ── Ligne 3 : Classement + Analyse des pertes ──────────── *@
        <div class="row g-3 mb-4">

            @* Classement *@
            <div class="col-lg-7">
                <div class="apple-card h-100" style="overflow: hidden;">
                    <div class="apple-section-header">
                        <span>Classement des Closeuses</span>
                    </div>
                    @if (!_leaderboard.Any())
                    {
                        <p style="color: #86868B; font-size: 0.875rem; text-align: center; padding: 2.5rem 1.5rem;">
                            Aucune donnée disponible.
                        </p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="apple-table">
                                <thead>
                                    <tr>
                                        <th style="width: 2.5rem;">#</th>
                                        <th>Closeuse</th>
                                        <th class="text-center">Closes</th>
                                        <th class="text-center">Taux</th>
                                        <th class="text-end">CA</th>
                                        <th class="text-end" style="padding-right: 1.5rem;">Collecté</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < _leaderboard.Count; i++)
                                    {
                                        var p    = _leaderboard[i];
                                        var rank = i + 1;
                                        var medal = rank switch { 1 => "🥇", 2 => "🥈", 3 => "🥉", _ => null };
                                        var ratePillClass = p.CloseRate >= 50 ? "rate-pill rate-pill-good"
                                                          : p.CloseRate >= 25 ? "rate-pill rate-pill-medium"
                                                          :                     "rate-pill rate-pill-poor";
                                        <tr>
                                            <td>
                                                @if (medal is not null)
                                                {
                                                    <span class="lb-medal">@medal</span>
                                                }
                                                else
                                                {
                                                    <span class="lb-rank-no">@rank</span>
                                                }
                                            </td>
                                            <td>
                                                <div style="font-weight: 600; color: #1D1D1F; font-size: 0.9rem;">@p.Name</div>
                                                @if (p.TotalCollected > 0)
                                                {
                                                    <div style="margin-top: 0.2rem;">
                                                        <span class="rate-pill" style="font-size: 0.65rem;">
                                                            Collecte : @p.CollectionRate %
                                                        </span>
                                                    </div>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div style="font-size: 1.05rem; font-weight: 700; color: #1D1D1F; line-height: 1;">@p.Closes</div>
                                                <div style="font-size: 0.7rem; color: #AEAEB2; margin-top: 0.1rem;">/ @p.TotalAssignments</div>
                                            </td>
                                            <td class="text-center">
                                                <span class="@ratePillClass">@p.CloseRate %</span>
                                            </td>
                                            <td class="text-end" style="color: #86868B; font-size: 0.82rem;">
                                                @p.TotalRevenue.ToString("C0", fr)
                                            </td>
                                            <td class="text-end val-positive" style="font-size: 0.875rem; padding-right: 1.5rem;">
                                                @p.TotalCollected.ToString("C0", fr)
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @* Analyse des Pertes *@
            <div class="col-lg-5">
                <div class="apple-card h-100" style="overflow: hidden;">
                    <div class="apple-section-header">
                        <span>Analyse des Pertes</span>
                    </div>
                    @if (!_lossByOutcome.Any())
                    {
                        <p style="color: #86868B; font-size: 0.875rem; text-align: center; padding: 2.5rem 1.5rem;">
                            Aucune perte enregistrée.
                        </p>
                    }
                    else
                    {
                        @foreach (var (outcome, count) in _lossByOutcome)
                        {
                            <div class="loss-row">
                                <span class="loss-label">@FormatOutcome(outcome)</span>
                                <span class="loss-count">@count</span>
                            </div>
                        }
                    }
                </div>
            </div>

        </div>

        @* ── Ligne 4 : Registre complet ─────────────────────────── *@
        <div class="apple-card" style="overflow: hidden;">
            <div class="apple-section-header">
                <span>Registre des Appels</span>
                <span class="rate-pill">@_allLogs.Count</span>
            </div>
            <div class="table-responsive">
                <table class="apple-table">
                    <thead>
                        <tr>
                            <th style="width: 2.5rem;"></th>
                            <th>Date</th>
                            <th>Closeuse</th>
                            <th>Client</th>
                            <th>Téléphone</th>
                            <th>Statut</th>
                            <th class="text-end">CA</th>
                            <th class="text-end">Collecté</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in _allLogs)
                        {
                            <tr>
                                <td style="padding-left: 1.25rem;">
                                    <button style="background: transparent; border: none; color: #007AFF; padding: 0; cursor: pointer;"
                                            title="Modifier les finances"
                                            @onclick="() => OpenEditModal(log)">
                                        <i class="bi bi-pencil-square fs-5"></i>
                                    </button>
                                </td>
                                <td style="color: #86868B; white-space: nowrap; font-size: 0.8rem;">
                                    @log.CreatedAt.ToLocalTime().ToString("dd MMM, HH:mm")
                                </td>
                                <td style="font-weight: 600; font-size: 0.875rem;">@log.CloserName</td>
                                <td style="font-size: 0.875rem;">@log.CustomerName</td>
                                <td style="color: #86868B; font-size: 0.8rem;">@log.PhoneNumber</td>
                                <td>
                                    <span class="badge @OutcomeBadgeCss(log.Outcome)">
                                        @FormatOutcome(log.Outcome)
                                    </span>
                                </td>
                                <td class="text-end">
                                    @if (log.Revenue > 0)
                                    {
                                        <span style="color: #86868B; font-size: 0.8rem;">@log.Revenue.ToString("C0", fr)</span>
                                    }
                                    else { <span class="val-zero">—</span> }
                                </td>
                                <td class="text-end">
                                    @if (log.AmountCollected > 0)
                                    {
                                        <span class="val-positive" style="font-size: 0.82rem;">@log.AmountCollected.ToString("C0", fr)</span>
                                    }
                                    else { <span class="val-zero">—</span> }
                                </td>
                                <td style="font-size: 0.78rem; color: #86868B; font-style: italic; max-width: 260px;">
                                    @log.Notes
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
}

@* ── Financial Edit Modal ────────────────────────────────────────────────── *@
@if (_showEditModal && _editingLog is not null)
{
    <div class="fin-modal-backdrop" @onclick="CloseEditModal">
        <div class="apple-card fin-modal-card" @onclick:stopPropagation="true">

            <h5 class="fin-modal-title">Modifier les Finances</h5>
            <p class="fin-modal-sub">
                Mise à jour manuelle pour <strong>@_editingLog.CloserName</strong>
            </p>

            <div class="mb-3">
                <label class="apple-form-label">CA Total (€)</label>
                <input type="number" step="0.01" class="form-control"
                       @bind="_editRevenue" @bind:event="oninput" />
            </div>

            <div class="mb-4">
                <label class="apple-form-label">Cash Collecté (€)</label>
                <input type="number" step="0.01" class="form-control"
                       @bind="_editCollected" @bind:event="oninput" />
            </div>

            @if (!string.IsNullOrEmpty(_editError))
            {
                <p class="fin-modal-error mb-3">@_editError</p>
            }

            <div class="d-flex gap-2">
                <button class="apple-action-btn apple-btn-gray flex-fill"
                        @onclick="CloseEditModal" disabled="@_saving">
                    Annuler
                </button>
                <button class="apple-action-btn apple-btn-blue flex-fill"
                        @onclick="SaveFinancials" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                    }
                    else
                    {
                        <span>Enregistrer</span>
                    }
                </button>
            </div>

        </div>
    </div>
}

@code {
    // ── Data ────────────────────────────────────────────────────────────────
    private List<AdminCallLog>                _allLogs    = [];
    private bool                              _loading    = true;
    private string?                           _error;

    // Basic call KPIs
    private int    _totalCalls;
    private int    _totalSales;
    private double _conversionRate;

    // Financial KPIs
    private decimal _totalRevenue;
    private decimal _totalCollected;
    private int     _numberOfBuyers;
    private decimal _averageOrderValue;

    // Leaderboard + loss breakdown
    private List<CloserPerformance>           _leaderboard   = [];
    private List<(string Outcome, int Count)> _lossByOutcome = [];

    // ── Financial edit modal state ───────────────────────────────────────────
    private bool         _showEditModal;
    private AdminCallLog? _editingLog;
    private decimal      _editRevenue;
    private decimal      _editCollected;
    private bool         _saving;
    private string       _editError = string.Empty;

    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (!state.User.IsInRole("Admin"))
        {
            _error   = "Accès refusé. Cette page est réservée aux administrateurs.";
            _loading = false;
            return;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error   = null;
        try
        {
            var actualLogs   = await ApiService.GetAdminCallLogsAsync();
            var reservations = await ApiService.GetAdminReservationsAsync();

            // Ghost entries: reservations with a sheet status but no matching call log.
            var ghostLogs = reservations
                .Where(r => !string.IsNullOrWhiteSpace(r.CurrentStatus)
                         && !actualLogs.Any(c => c.PhoneNumber == r.PhoneNumber))
                .Select(r => new AdminCallLog
                {
                    Id              = Guid.Empty,
                    CloserName      = r.CloserName,
                    CustomerName    = r.CustomerName,
                    PhoneNumber     = r.PhoneNumber,
                    Outcome         = r.CurrentStatus!,
                    Notes           = string.IsNullOrWhiteSpace(r.Notes)
                                          ? "*(Mis à jour manuellement via Google Sheets, sans commentaire)*"
                                          : $"{r.Notes} *(Via Google Sheets)*",
                    Revenue         = 0,
                    AmountCollected = 0,
                    CreatedAt       = r.AppointmentDate == DateTime.MinValue
                                          ? DateTime.UtcNow
                                          : r.AppointmentDate
                });

            _allLogs = actualLogs
                .Concat(ghostLogs)
                .OrderByDescending(l => l.CreatedAt)
                .ToList();

            RecalculateDashboardMetrics();
        }
        catch (Exception ex)
        {
            _error = $"Impossible de charger les données : {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    // ── KPI recalculation — runs after every data load or local financial edit ──
    private void RecalculateDashboardMetrics()
    {
        _totalCalls     = _allLogs.Count;
        _totalSales     = _allLogs.Count(l => IsVente(l.Outcome));
        _conversionRate = _totalCalls > 0
            ? Math.Round((double)_totalSales / _totalCalls * 100, 1)
            : 0;

        var sales          = _allLogs.Where(l => IsVente(l.Outcome)).ToList();
        _numberOfBuyers    = sales.Count;
        _totalRevenue      = sales.Sum(l => l.Revenue);
        _totalCollected    = sales.Sum(l => l.AmountCollected);
        _averageOrderValue = _numberOfBuyers > 0 ? _totalCollected / _numberOfBuyers : 0;

        _leaderboard = _allLogs
            .Where(l => !string.IsNullOrWhiteSpace(l.CloserName))
            .GroupBy(l => l.CloserName)
            .Select(g => new CloserPerformance
            {
                Name             = g.Key,
                TotalAssignments = g.Count(),
                Closes           = g.Count(l => IsVente(l.Outcome)),
                TotalRevenue     = g.Where(l => IsVente(l.Outcome)).Sum(l => l.Revenue),
                TotalCollected   = g.Where(l => IsVente(l.Outcome)).Sum(l => l.AmountCollected)
            })
            .OrderByDescending(c => c.Closes)
            .ThenByDescending(c => c.TotalRevenue)
            .ToList();

        _lossByOutcome = _allLogs
            .Where(l => !IsVente(l.Outcome))
            .GroupBy(l => l.Outcome)
            .Select(g => (Outcome: g.Key, Count: g.Count()))
            .OrderByDescending(x => x.Count)
            .ToList();
    }

    // ── Financial edit modal ─────────────────────────────────────────────────
    private void OpenEditModal(AdminCallLog log)
    {
        _editingLog    = log;
        _editRevenue   = log.Revenue;
        _editCollected = log.AmountCollected;
        _editError     = string.Empty;
        _showEditModal = true;
    }

    private void CloseEditModal()
    {
        _showEditModal = false;
        _editingLog    = null;
        _editError     = string.Empty;
    }

    private async Task SaveFinancials()
    {
        if (_editingLog is null) return;

        // Ghost logs (synced from Google Sheets only, no DB record) cannot be updated.
        if (_editingLog.Id == Guid.Empty)
        {
            _editError = "Cette entrée provient de Google Sheets et n'est pas encore en base de données. Elle ne peut pas être modifiée ici.";
            return;
        }

        _saving    = true;
        _editError = string.Empty;
        try
        {
            var ok = await ApiService.UpdateCallLogFinancialsAsync(
                _editingLog.Id, _editRevenue, _editCollected);

            if (ok)
            {
                _editingLog.Revenue         = _editRevenue;
                _editingLog.AmountCollected = _editCollected;
                RecalculateDashboardMetrics();
                CloseEditModal();
            }
            else
            {
                _editError = "Échec de la mise à jour. Réessayez.";
            }
        }
        catch
        {
            _editError = "Erreur réseau — vérifiez la connexion.";
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Helpers ──────────────────────────────────────────────────────────────
    private static bool IsVente(string outcome) =>
        outcome == "Answered_Available" ||
        outcome.Contains("Vente", StringComparison.OrdinalIgnoreCase);

    private static string FormatOutcome(string outcome) => outcome switch
    {
        "Answered_Available"        => "Vente (App)",
        "Answered_NotAvailable"     => "Pas de Vente — Rappel",
        "NotAnswered_VoicemailLeft" => "Pas Répondu — Messagerie",
        "NotAnswered_NoVoicemail"   => "Pas Répondu — Sans Message",
        "NotAnswered_VoicemailFull" => "Pas Répondu — Messagerie Pleine",
        _                           => outcome
    };

    private static string OutcomeBadgeCss(string outcome)
    {
        if (IsVente(outcome))                                                   return "bg-success";
        if (outcome == "Answered_NotAvailable")                                 return "bg-warning text-dark";
        if (outcome.Equals("R2", StringComparison.OrdinalIgnoreCase))           return "bg-info text-dark";
        if (outcome.Contains("Annulation", StringComparison.OrdinalIgnoreCase)) return "bg-danger";
        return "bg-secondary";
    }

    public class CloserPerformance
    {
        public string  Name             { get; set; } = "";
        public int     TotalAssignments { get; set; }
        public int     Closes           { get; set; }
        public decimal TotalRevenue     { get; set; }
        public decimal TotalCollected   { get; set; }

        public double CloseRate      => TotalAssignments > 0
            ? Math.Round((double)Closes / TotalAssignments * 100, 1) : 0;
        public double CollectionRate => TotalRevenue > 0
            ? Math.Round((double)TotalCollected / (double)TotalRevenue * 100, 1) : 0;
    }
}
