@page "/admin"
@rendermode InteractiveServer
@inject ApiService ApiService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@using System.Globalization

<PageTitle>Centre de Contrôle — CallLog CRM</PageTitle>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="text-muted small mt-2">Chargement des données…</p>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger m-4">@_error</div>
}
else
{
    var fr = new CultureInfo("fr-FR");

    <div class="container-fluid mt-4 pb-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">
                <i class="bi bi-speedometer2 me-2"></i> Centre de Contrôle
            </h2>
            <button class="btn btn-outline-secondary btn-sm" @onclick="LoadData">
                <i class="bi bi-arrow-clockwise me-1"></i> Rafraîchir
            </button>
        </div>

        @* ── Ligne 1 : KPIs Financiers ───────────────────────────── *@
        <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #0d6efd !important;">
                    <div class="card-body py-3 px-3">
                        <p class="text-uppercase fw-semibold small text-muted mb-1">CA Total</p>
                        <h3 class="fw-bold mb-0 text-primary">@_totalRevenue.ToString("C0", fr)</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #198754 !important;">
                    <div class="card-body py-3 px-3">
                        <p class="text-uppercase fw-semibold small text-muted mb-1">Cash Collecté</p>
                        <h3 class="fw-bold mb-0 text-success">@_totalCollected.ToString("C0", fr)</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #ffc107 !important;">
                    <div class="card-body py-3 px-3">
                        <p class="text-uppercase fw-semibold small text-muted mb-1">Acheteurs</p>
                        <h3 class="fw-bold mb-0 text-warning">@_numberOfBuyers</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #0dcaf0 !important;">
                    <div class="card-body py-3 px-3">
                        <p class="text-uppercase fw-semibold small text-muted mb-1">Panier Moyen (Collecté)</p>
                        <h3 class="fw-bold mb-0 text-info">@_averageOrderValue.ToString("C0", fr)</h3>
                    </div>
                </div>
            </div>
        </div>

        @* ── Ligne 2 : KPIs Appels ───────────────────────────────── *@
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 bg-primary text-white h-100 shadow-sm">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center py-4">
                        <p class="text-uppercase fw-bold small opacity-75 mb-1">Appels Totaux</p>
                        <h1 class="display-4 fw-bold mb-0">@_totalCalls</h1>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-success text-white h-100 shadow-sm">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center py-4">
                        <p class="text-uppercase fw-bold small opacity-75 mb-1">Ventes Conclues</p>
                        <h1 class="display-4 fw-bold mb-0">@_totalSales</h1>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-dark text-white h-100 shadow-sm">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center py-4">
                        <p class="text-uppercase fw-bold small text-secondary mb-1">Taux de Conversion</p>
                        <h1 class="display-4 fw-bold text-info mb-0">@_conversionRate %</h1>
                    </div>
                </div>
            </div>
        </div>

        @* ── Ligne 3 : Classement + Analyse des pertes ───────────── *@
        <div class="row g-3 mb-4">

            @* ── Classement des Closeuses ── *@
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h5 class="fw-bold mb-3">
                            <i class="bi bi-trophy-fill text-warning me-2"></i> Classement des Closeuses
                        </h5>
                    </div>
                    <div class="card-body pt-0 px-0 pb-0">
                        @if (!_leaderboard.Any())
                        {
                            <p class="text-muted small text-center py-3 px-3">Aucune donnée disponible.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0 align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-3" style="width:3rem">#</th>
                                            <th>Closeuse</th>
                                            <th class="text-center">Closes</th>
                                            <th class="text-center">Taux</th>
                                            <th class="text-end">CA</th>
                                            <th class="text-end pe-3">Collecté</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < _leaderboard.Count; i++)
                                        {
                                            var p    = _leaderboard[i];
                                            var rank = i + 1;
                                            var medal = rank switch { 1 => "🥇", 2 => "🥈", 3 => "🥉", _ => $"{rank}." };
                                            var rowClass = rank switch { 1 => "table-warning", 2 => "table-light", 3 => "", _ => "" };
                                            <tr class="@rowClass">
                                                <td class="ps-3 fw-bold fs-5">@medal</td>
                                                <td>
                                                    <span class="fw-semibold">@p.Name</span>
                                                    @if (p.TotalCollected > 0)
                                                    {
                                                        <br />
                                                        <small class="text-muted">
                                                            Collecte : @p.CollectionRate %
                                                        </small>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-success rounded-pill">@p.Closes</span>
                                                    <br />
                                                    <small class="text-muted">/ @p.TotalAssignments</small>
                                                </td>
                                                <td class="text-center">
                                                    <span class="fw-semibold @(p.CloseRate >= 50 ? "text-success" : p.CloseRate >= 25 ? "text-warning" : "text-danger")">
                                                        @p.CloseRate %
                                                    </span>
                                                </td>
                                                <td class="text-end text-muted small">@p.TotalRevenue.ToString("C0", fr)</td>
                                                <td class="text-end pe-3 fw-semibold text-success">@p.TotalCollected.ToString("C0", fr)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* ── Analyse des Pertes ── *@
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h5 class="fw-bold mb-3">
                            <i class="bi bi-pie-chart text-danger me-2"></i> Analyse des Pertes
                        </h5>
                    </div>
                    <div class="card-body pt-2">
                        @if (!_lossByOutcome.Any())
                        {
                            <p class="text-muted small text-center py-3">Aucune perte enregistrée.</p>
                        }
                        else
                        {
                            @foreach (var (outcome, count) in _lossByOutcome)
                            {
                                <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded">
                                    <span class="fw-semibold text-secondary small">@FormatOutcome(outcome)</span>
                                    <span class="badge bg-danger rounded-pill">@count</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

        </div>

        @* ── Ligne 4 : Registre complet ──────────────── *@
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-list-columns-reverse me-2"></i>
                    Registre Complet des Appels
                    <span class="badge bg-secondary ms-2 fw-normal">@_allLogs.Count</span>
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Closeuse</th>
                                <th>Client</th>
                                <th>Téléphone</th>
                                <th>Statut</th>
                                <th class="text-end">CA</th>
                                <th class="text-end">Collecté</th>
                                <th>Notes / Explications</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in _allLogs)
                            {
                                <tr>
                                    <td class="text-muted small text-nowrap">
                                        @log.CreatedAt.ToLocalTime().ToString("dd MMM, HH:mm")
                                    </td>
                                    <td class="fw-semibold small">@log.CloserName</td>
                                    <td class="small">@log.CustomerName</td>
                                    <td class="text-muted small">@log.PhoneNumber</td>
                                    <td>
                                        <span class="badge @OutcomeBadgeCss(log.Outcome) rounded-pill">
                                            @FormatOutcome(log.Outcome)
                                        </span>
                                    </td>
                                    <td class="text-end small">
                                        @if (log.Revenue > 0)
                                        {
                                            <span class="text-muted">@log.Revenue.ToString("C0", fr)</span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td class="text-end small">
                                        @if (log.AmountCollected > 0)
                                        {
                                            <span class="fw-semibold text-success">@log.AmountCollected.ToString("C0", fr)</span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td class="small fst-italic text-secondary">@log.Notes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
}

@code {
    private List<AdminCallLog>           _allLogs    = [];
    private bool                         _loading    = true;
    private string?                      _error;

    // Basic call KPIs
    private int    _totalCalls;
    private int    _totalSales;
    private double _conversionRate;

    // Financial KPIs
    private decimal _totalRevenue;
    private decimal _totalCollected;
    private int     _numberOfBuyers;
    private decimal _averageOrderValue;

    // Leaderboard
    private List<CloserPerformance> _leaderboard = [];

    // Loss breakdown
    private List<(string Outcome, int Count)> _lossByOutcome = [];

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (!state.User.IsInRole("Admin"))
        {
            _error   = "Accès refusé. Cette page est réservée aux administrateurs.";
            _loading = false;
            return;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error   = null;
        try
        {
            var actualLogs   = await ApiService.GetAdminCallLogsAsync();
            var reservations = await ApiService.GetAdminReservationsAsync();

            // Ghost entries: reservations that have a sheet status but no matching call log.
            var ghostLogs = reservations
                .Where(r => !string.IsNullOrWhiteSpace(r.CurrentStatus)
                         && !actualLogs.Any(c => c.PhoneNumber == r.PhoneNumber))
                .Select(r => new AdminCallLog
                {
                    Id              = Guid.Empty,
                    CloserName      = r.CloserName,
                    CustomerName    = r.CustomerName,
                    PhoneNumber     = r.PhoneNumber,
                    Outcome         = r.CurrentStatus!,
                    Notes           = string.IsNullOrWhiteSpace(r.Notes)
                                          ? "*(Mis à jour manuellement via Google Sheets, sans commentaire)*"
                                          : $"{r.Notes} *(Via Google Sheets)*",
                    Revenue         = 0,
                    AmountCollected = 0,
                    CreatedAt       = r.AppointmentDate == DateTime.MinValue
                                          ? DateTime.UtcNow
                                          : r.AppointmentDate
                });

            _allLogs = actualLogs
                .Concat(ghostLogs)
                .OrderByDescending(l => l.CreatedAt)
                .ToList();

            // ── Basic call KPIs ──────────────────────────────────────
            _totalCalls     = _allLogs.Count;
            _totalSales     = _allLogs.Count(l => IsVente(l.Outcome));
            _conversionRate = _totalCalls > 0
                ? Math.Round((double)_totalSales / _totalCalls * 100, 1)
                : 0;

            // ── Financial KPIs ───────────────────────────────────────
            var sales       = _allLogs.Where(l => IsVente(l.Outcome)).ToList();
            _numberOfBuyers    = sales.Count;
            _totalRevenue      = sales.Sum(l => l.Revenue);
            _totalCollected    = sales.Sum(l => l.AmountCollected);
            _averageOrderValue = _numberOfBuyers > 0 ? _totalCollected / _numberOfBuyers : 0;

            // ── Leaderboard ──────────────────────────────────────────
            _leaderboard = _allLogs
                .Where(l => !string.IsNullOrWhiteSpace(l.CloserName))
                .GroupBy(l => l.CloserName)
                .Select(g => new CloserPerformance
                {
                    Name             = g.Key,
                    TotalAssignments = g.Count(),
                    Closes           = g.Count(l => IsVente(l.Outcome)),
                    TotalRevenue     = g.Where(l => IsVente(l.Outcome)).Sum(l => l.Revenue),
                    TotalCollected   = g.Where(l => IsVente(l.Outcome)).Sum(l => l.AmountCollected)
                })
                .OrderByDescending(c => c.Closes)
                .ThenByDescending(c => c.TotalRevenue)
                .ToList();

            // ── Loss breakdown ───────────────────────────────────────
            _lossByOutcome = _allLogs
                .Where(l => !IsVente(l.Outcome))
                .GroupBy(l => l.Outcome)
                .Select(g => (Outcome: g.Key, Count: g.Count()))
                .OrderByDescending(x => x.Count)
                .ToList();
        }
        catch (Exception ex)
        {
            _error = $"Impossible de charger les données : {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private static bool IsVente(string outcome) =>
        outcome == "Answered_Available" ||
        outcome.Contains("Vente", StringComparison.OrdinalIgnoreCase);

    private static string FormatOutcome(string outcome) => outcome switch
    {
        "Answered_Available"        => "Vente (App)",
        "Answered_NotAvailable"     => "Pas de Vente — Rappel",
        "NotAnswered_VoicemailLeft" => "Pas Répondu — Messagerie",
        "NotAnswered_NoVoicemail"   => "Pas Répondu — Sans Message",
        "NotAnswered_VoicemailFull" => "Pas Répondu — Messagerie Pleine",
        _                           => outcome
    };

    private static string OutcomeBadgeCss(string outcome)
    {
        if (IsVente(outcome))                                                   return "bg-success";
        if (outcome == "Answered_NotAvailable")                                 return "bg-warning text-dark";
        if (outcome.Equals("R2", StringComparison.OrdinalIgnoreCase))           return "bg-info text-dark";
        if (outcome.Contains("Annulation", StringComparison.OrdinalIgnoreCase)) return "bg-danger";
        return "bg-secondary";
    }

    public class CloserPerformance
    {
        public string  Name             { get; set; } = "";
        public int     TotalAssignments { get; set; }
        public int     Closes           { get; set; }
        public decimal TotalRevenue     { get; set; }
        public decimal TotalCollected   { get; set; }

        public double CloseRate      => TotalAssignments > 0
            ? Math.Round((double)Closes / TotalAssignments * 100, 1) : 0;
        public double CollectionRate => TotalRevenue > 0
            ? Math.Round((double)TotalCollected / (double)TotalRevenue * 100, 1) : 0;
    }
}
